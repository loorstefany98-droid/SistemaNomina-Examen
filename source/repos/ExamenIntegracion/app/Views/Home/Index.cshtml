@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Sistema de Nomina</h1>

    <p class="lead mt-3">
        Sistema web desarrollado en ASP.NET Core para la gestión y cálculo automático
        de nómina de empleados.
    </p>

    <hr class="my-4" />

    <div class="row mt-4">

        <div class="col-md-3">
            <div class="card shadow p-3 mb-4 bg-white rounded">
                <h5>🔐 Login</h5>
                <p>Acceso al sistema .</p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-dark">
                    Iniciar Sesión
                </a>
            </div>
        </div>

    </div>

    <hr />

    <div class="mt-4">
        <p><strong>Proyecto Académico – Desarrollo Web</strong></p>
        <p>Grupo 4</p>
        <p></p>
    </div>

</div>
    
