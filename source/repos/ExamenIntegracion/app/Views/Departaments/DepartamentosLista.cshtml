@model List<app.Models.Departments>

@{
    ViewData["Title"] = "Lista de Departamentos";
}

<h2>Lista de Departamentos</h2>

<!-- Botón Create -->
<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Departaments" asp-action="Create">
        Create Department
    </a>
</div>

<!-- Menú como tu imagen -->
<div class="d-grid gap-2" style="max-width:340px;">
    <a class="btn btn-primary" asp-controller="Departaments" asp-action="GerentedeDepartamento">
        👥 Gerente De Departamento
    </a>

    <a class="btn btn-primary" asp-controller="Departaments" asp-action="DepartamentosLista">
        👥 Lista de Departamentos
    </a>

    <a class="btn btn-primary" asp-controller="Departaments" asp-action="DepartamentosFormulario">
        👥 Formulario de Departamentos
    </a>

    <a class="btn btn-primary" asp-controller="Departaments" asp-action="AsignacionDepartamento">
        👥 Asignacion de Departamentos
    </a>
</div>

<hr />

<!-- Tabla desde SQL -->
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>dept_no</th>
            <th>dept_name</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.dept_no</td>
                <td>@d.dept_name</td>
            </tr>
        }
    </tbody>
</table>