@model List<app.Models.salaries>

<table class="table">
    <thead>
        <tr>
            <th>Empleado</th>
            <th>Salario</th>
            <th>Desde</th>
            <th>Hasta</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.emp_no</td>
                    <td>@item.salary</td>
                    <td>@item.from_date</td>
                    <td>@item.to_date</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.emp_no" class="btn btn-warning">Editar</a>
                        <a asp-action="TerminarVigencia" asp-route-id="@item.emp_no" class="btn btn-danger">Terminar</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">No hay datos de salarios cargados.</td>
            </tr>
        }
    </tbody>
</table>