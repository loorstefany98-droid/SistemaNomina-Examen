@{
    ViewData["Title"] = "Employees";
}

<h2 class="mt-4 mb-4">Employees List</h2>

<!-- Botón principal para crear un empleado -->
<a asp-action="Create" class="btn btn-success mb-3">Create Employee</a>

<!-- Tabla de empleados con estilo -->
<table class="table table-striped table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Department</th>
            <th style="width: 220px;">Actions</th> <!-- ancho fijo para los botones -->
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Alejandro Hernandez</td>
            <td>TIC</td>
            <td>
                <a asp-action="Edit" class="btn btn-sm btn-warning me-1">Edit</a>
                <a asp-action="Delete" class="btn btn-sm btn-danger me-1">Delete</a>
                <a asp-action="Details" class="btn btn-sm btn-info">View</a>
            </td>
        </tr>
        <!-- Más filas de ejemplo -->
        <tr>
            <td>Maria Lopez</td>
            <td>HR</td>
            <td>
                <a asp-action="Edit" class="btn btn-sm btn-warning me-1">Edit</a>
                <a asp-action="Delete" class="btn btn-sm btn-danger me-1">Delete</a>
                <a asp-action="Details" class="btn btn-sm btn-info">View</a>
            </td>
        </tr>
    </tbody>
</table>
<div class="col-md-3">

    <a asp-controller="Employees" " asp-action="EmpleadosFormulario" class="btn btn-primary w-100 mb-2">
        👥 Formulario de Empleados
    </a>
</div>