@model app.Models.employees

@{
    ViewData["Title"] = "Create Employee";
}

<h2 class="mt-4">Create Employee</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">CI</label>
        <input asp-for="ci" class="form-control" required />
        <span asp-validation-for="ci" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Birth Date (YYYY-MM-DD)</label>
        <input asp-for="birth_date" class="form-control" required />
        <span asp-validation-for="birth_date" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">First Name</label>
        <input asp-for="first_name" class="form-control" required />
        <span asp-validation-for="first_name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Last Name</label>
        <input asp-for="last_name" class="form-control" required />
        <span asp-validation-for="last_name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Gender (M o F)</label>
        <select asp-for="gender" class="form-select" required>
            <option value="">-- Select --</option>
            <option value="M">M</option>
            <option value="F">F</option>
        </select>
        <span asp-validation-for="gender" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Hire Date (YYYY-MM-DD)</label>
        <input asp-for="hire_date" class="form-control" required />
        <span asp-validation-for="hire_date" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Correo (opcional)</label>
        <input asp-for="correo" class="form-control" />
        <span asp-validation-for="correo" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
