@model IEnumerable<app.Models.employees>

@{
    ViewData["Title"] = "Employees List";
}

<h2 class="mt-4">Employees List</h2>

<a asp-action="Create" class="btn btn-success mb-3">Create Employee</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Emp #</th>
            <th>CI</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Gender</th>
            <th>Birth Date</th>
            <th>Hire Date</th>
            <th>Correo</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.emp_no</td>
                <td>@item.ci</td>
                <td>@item.first_name</td>
                <td>@item.last_name</td>
                <td>@item.gender</td>
                <td>@item.birth_date</td>
                <td>@item.hire_date</td>
                <td>@item.correo</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.emp_no" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.emp_no" class="btn btn-info btn-sm">View</a>
                    <a asp-action="Delete" asp-route-id="@item.emp_no" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
